{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "Goose 2FA",
  "version": "0.1.0",
  "identifier": "com.goose2fa.app",
  "build": {
    "beforeDevCommand": "vite -c vite.config.tauri.ts --port 6002",
    "beforeBuildCommand": "vite build -c vite.config.tauri.ts",
    "frontendDist": "../dist-tauri",
    "devUrl": "http://localhost:6002"
  },
  "app": {
    "windows": [
      {
        "title": "Goose 2FA",
        "width": 480,
        "height": 660,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
